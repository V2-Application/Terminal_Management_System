}

async function purgeHB(){
  if(!confirm('Purge heartbeats older than 30 days?'))return;
  const r=await api('/Admin/Heartbeats/purge','DELETE',{olderThanDays:30});
  if(r?.success){toast('Purged '+r.deleted+' records');loadHB(1);}
}

/* ══ AUDIT LOGS ════════════════════════════════════════════════════════════ */
let auPage=1;
async function loadAudit(p=1){
  auPage=p;
  const q=new URLSearchParams({action:document.getElementById('a-action')?.value||'',entityType:document.getElementById('a-entity')?.value||'',userId:document.getElementById('a-user')?.value||'',page:p,pageSize:50});
  const d=await api('/Admin/AuditLogs?'+q);
  if(!d){document.getElementById('audit-wrap').innerHTML='<div style="padding:20px;font-family:monospace;font-size:12px;color:#F09595">Failed to load</div>';return;}
  const rows=d.items.map(a=>`
    <div style="display:flex;gap:14px;margin-bottom:3px">
      <span style="color:#378ADD;white-space:nowrap;min-width:135px;font-size:12px">${new Date(a.timestamp).toLocaleString()}</span>
      <span style="color:#72D3A6;min-width:90px;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${(a.userId||'').substring(0,18)}</span>
      <span style="color:${a.result==='SUCCESS'?'#97C459':'#F09595'};min-width:190px;font-size:12px;white-space:nowrap">${a.action}</span>
      <span style="color:#9FA8A3;font-size:12px">${a.entityType}/${a.entityId}${a.details?' — '+(a.details.length>55?a.details.substring(0,55)+'…':a.details):''}</span>
    </div>`).join('');
  document.getElementById('audit-wrap').innerHTML=`
    <div style="padding:8px 14px;border-bottom:1px solid #1A1A1A;display:flex;justify-content:space-between">
      <span style="font-family:monospace;font-size:12px;color:#72D3A6">// Audit Log — ${d.total} entries</span>
    </div>
    <div style="padding:8px 14px;max-height:500px;overflow-y:auto;font-family:monospace">${rows||'<div style="color:#555">No entries</div>'}</div>`;
  document.getElementById('audit-pages').innerHTML=pages(d.total,auPage,50,'loadAudit');
}

/* ── Init ─────────────────────────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded',()=>{
  loadKPI();
  loadStores(1);
  setInterval(loadKPI,30000);
});
</script>
