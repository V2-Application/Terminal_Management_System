async function loadTerminals(p) {
    if(p) terminalsPage = p;
    const search = document.getElementById('terminal-search')?.value||'';
    const status = document.getElementById('terminal-status')?.value||'';
    const params = new URLSearchParams({search,status,page:terminalsPage,pageSize:20});
    const d = await fetch('/Admin/Terminals?'+params).then(r=>r.json());
    const tbody = d.items.map(t=>`
        <tr style="border-bottom:1px solid #F0F0F0" onclick="editTerminal('${t.terminalId}','${t.terminalCode}')">
            <td style="padding:9px 12px;font-family:monospace;font-size:12px;font-weight:600;color:#1F3864">${t.terminalCode}</td>
            <td style="padding:9px 12px;font-size:12px;color:#555">${t.storeCode}</td>
            <td style="padding:9px 12px;font-size:12px;color:#888">${t.machineName}</td>
            <td style="padding:9px 12px;font-family:monospace;font-size:11px;color:#888">${t.ipAddress||'—'}</td>
            <td style="padding:9px 12px">${badge(t.status)}</td>
            <td style="padding:9px 12px;font-family:monospace;font-size:11px">${t.agentVersion||'—'}</td>
            <td style="padding:9px 12px;font-size:12px;color:${(t.diskFreeGB||0)<5?'#A32D2D':'#3B6D11'}">${t.diskFreeGB?t.diskFreeGB.toFixed(0)+' GB':'—'}</td>
            <td style="padding:9px 12px;font-size:11px;color:#888">${t.lastHeartbeat?new Date(t.lastHeartbeat).toLocaleTimeString()+' '+new Date(t.lastHeartbeat).toLocaleDateString():'Never'}</td>
            <td style="padding:9px 12px;text-align:center"><span style="font-size:11px;color:${t.isPrimary?'#185FA5':'#888'}">${t.isPrimary?'★ Yes':'No'}</span></td>
            <td style="padding:9px 12px" onclick="event.stopPropagation()">
                <div style="display:flex;gap:4px">
                    <button onclick="setTerminalStatus('${t.terminalId}','${t.terminalCode}')"
                            style="padding:3px 8px;font-size:11px;background:#FAEEDA;color:#854F0B;border:none;border-radius:4px;cursor:pointer">Status</button>
                    <button onclick="deleteTerminal('${t.terminalId}','${t.terminalCode}')"
