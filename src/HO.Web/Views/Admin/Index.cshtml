async function loadCommands(p){
    if(p) commandsPage=p;
    const status=document.getElementById('cmd-status')?.value||'';
    const type=document.getElementById('cmd-type')?.value||'';
    const params=new URLSearchParams({status,commandType:type,page:commandsPage,pageSize:20});
    const d=await fetch('/Admin/Commands?'+params).then(r=>r.json());
    const tbody=d.items.map(c=>`
        <tr style="border-bottom:1px solid #F0F0F0">
            <td style="padding:8px 12px;font-family:monospace;font-size:11px;color:#888">${c.commandId.substring(0,8)}…</td>
            <td style="padding:8px 12px;font-size:12px;font-weight:600;color:#1F3864">${c.storeCode}</td>
            <td style="padding:8px 12px;font-size:11px"><span style="background:#E6F1FB;color:#185FA5;padding:2px 7px;border-radius:4px">${c.commandType}</span></td>
            <td style="padding:8px 12px">${badge(c.status)}</td>
            <td style="padding:8px 12px;text-align:center;font-size:12px">${c.retryCount}/${c.maxRetries}</td>
            <td style="padding:8px 12px;font-size:11px;color:${c.lastExitCode===0?'#3B6D11':c.lastExitCode!==null?'#A32D2D':'#888'}">${c.lastExitCode!==null?'Exit: '+c.lastExitCode:'—'}</td>
            <td style="padding:8px 12px;font-size:11px;color:#888">${c.createdAt?new Date(c.createdAt).toLocaleString():''}</td>
            <td style="padding:8px 12px;font-size:11px;color:#888">${c.completedAt?new Date(c.completedAt).toLocaleTimeString():'—'}</td>
            <td style="padding:8px 12px">
                <div style="display:flex;gap:4px">
                    <button onclick="setCommandStatus('${c.commandId}')"
                            style="padding:3px 8px;font-size:11px;background:#FAEEDA;color:#854F0B;border:none;border-radius:4px;cursor:pointer">Status</button>
                    ${c.status==='Queued'||c.status==='Dispatched'?
                        `<button onclick="cancelCommand('${c.commandId}')"
                                 style="padding:3px 8px;font-size:11px;background:#FCEBEB;color:#A32D2D;border:none;border-radius:4px;cursor:pointer">Cancel</button>`:''}
                </div>
            </td>
        </tr>`).join('');
    document.getElementById('commands-table-wrap').innerHTML=`
        <table style="width:100%;border-collapse:collapse">
            <thead><tr style="background:#F8F9FA;border-bottom:2px solid #E8E8E8">
                ${['ID','Store','Type','Status','Retries','Exit','Created','Completed','Actions'].map(h=>`<th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap">${h}</th>`).join('')}
            </tr></thead><tbody>${tbody}</tbody>
        </table>
        <div style="padding:8px 12px;border-top:1px solid #F0F0F0;font-size:12px;color:#888">${d.total} commands total</div>`;
    document.getElementById('commands-pagination').innerHTML=pagination(d.total,commandsPage,20,'loadCommands');
}

