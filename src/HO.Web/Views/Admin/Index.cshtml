@{
    ViewData["Title"] = "Admin — Configuration & CRUD";
}

<!-- Tab navigation -->
<div style="display:flex;gap:0;margin-bottom:0;border-bottom:2px solid #E8E8E8;overflow-x:auto">
    @{
        var tabs = new[]{
            ("stores",    "🏪 Stores"),
            ("terminals", "🖥️ Terminals"),
            ("commands",  "⚙ Commands"),
            ("fyjobs",    "📅 FY Jobs"),
            ("packages",  "📦 Packages"),
            ("heartbeats","💓 Heartbeats"),
            ("audit",     "📋 Audit Logs"),
        };
    }
    @foreach (var (id, label) in tabs)
    {
        <button class="tab-btn" data-tab="@id"
                onclick="switchTab('@id')"
                style="padding:10px 18px;font-size:13px;font-weight:500;border:none;background:transparent;cursor:pointer;color:#888;white-space:nowrap;border-bottom:2px solid transparent;margin-bottom:-2px">
            @label
        </button>
    }
</div>

<!-- Summary bar -->
<div id="summary-bar" style="display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin:14px 0">
    <div style="background:#F8F9FA;border-radius:7px;padding:10px;text-align:center;border:1px solid #EEE">
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.05em">Stores</div>
        <div id="sum-stores" style="font-size:20px;font-weight:700;font-family:monospace;color:#1F3864">—</div>
    </div>
    <div style="background:#EAF3DE;border-radius:7px;padding:10px;text-align:center;border:1px solid #C8E6B4">
        <div style="font-size:10px;color:#3B6D11;text-transform:uppercase;letter-spacing:.05em">Online</div>
        <div id="sum-online" style="font-size:20px;font-weight:700;font-family:monospace;color:#3B6D11">—</div>
    </div>
    <div style="background:#FAEEDA;border-radius:7px;padding:10px;text-align:center;border:1px solid #F0CFA0">
        <div style="font-size:10px;color:#854F0B;text-transform:uppercase;letter-spacing:.05em">Commands</div>
        <div id="sum-commands" style="font-size:20px;font-weight:700;font-family:monospace;color:#854F0B">—</div>
    </div>
    <div style="background:#FCEBEB;border-radius:7px;padding:10px;text-align:center;border:1px solid #F5B8B8">
        <div style="font-size:10px;color:#A32D2D;text-transform:uppercase;letter-spacing:.05em">Failed</div>
        <div id="sum-failed" style="font-size:20px;font-weight:700;font-family:monospace;color:#A32D2D">—</div>
    </div>
    <div style="background:#E6F1FB;border-radius:7px;padding:10px;text-align:center;border:1px solid #B5D4F4">
        <div style="font-size:10px;color:#185FA5;text-transform:uppercase;letter-spacing:.05em">Packages</div>
        <div id="sum-packages" style="font-size:20px;font-weight:700;font-family:monospace;color:#185FA5">—</div>
    </div>
    <div style="background:#F0F0F0;border-radius:7px;padding:10px;text-align:center;border:1px solid #DDD">
        <div style="font-size:10px;color:#555;text-transform:uppercase;letter-spacing:.05em">Heartbeats 24h</div>
        <div id="sum-hb" style="font-size:20px;font-weight:700;font-family:monospace;color:#555">—</div>
    </div>
</div>

<!-- Toast container -->
<div id="toast-container" style="position:fixed;top:60px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px"></div>

<!-- Modal overlay -->
<div id="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:8000;align-items:center;justify-content:center">
    <div id="modal-box" style="background:#fff;border-radius:12px;padding:24px;min-width:480px;max-width:600px;max-height:80vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.2)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
            <h3 id="modal-title" style="font-size:16px;font-weight:700;color:#1F3864;margin:0"></h3>
            <button onclick="closeModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#888;line-height:1">×</button>
        </div>
        <div id="modal-body"></div>
        <div id="modal-footer" style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px;padding-top:14px;border-top:1px solid #EEE"></div>
    </div>
</div>

<!-- ═══ TAB CONTENT ═══════════════════════════════════════════════════════════ -->

<!-- STORES tab -->
<div id="tab-stores" class="tab-content" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <input id="store-search" placeholder="Search code / name…" oninput="loadStores()"
                   style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:180px"/>
            <select id="store-region" onchange="loadStores()"
                    style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
                <option value="">All Regions</option>
                <option>North</option><option>South</option><option>East</option>
                <option>West</option><option>Central</option>
            </select>
            <select id="store-status" onchange="loadStores()"
                    style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
                <option value="">All Statuses</option>
                <option>Active</option><option>Inactive</option><option>Decommissioned</option>
            </select>
        </div>
        <button onclick="showCreateStore()"
                style="padding:7px 16px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer">
            + Add Store
        </button>
    </div>
    <div id="stores-table-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
        <div style="padding:32px;text-align:center;color:#888">Loading...</div>
    </div>
    <div id="stores-pagination" style="display:flex;gap:6px;margin-top:10px;justify-content:center"></div>
</div>

<!-- TERMINALS tab -->
<div id="tab-terminals" class="tab-content" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <input id="terminal-search" placeholder="Search terminal / machine…" oninput="loadTerminals()"
                   style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:200px"/>
            <select id="terminal-status" onchange="loadTerminals()"
                    style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
                <option value="">All Statuses</option>
                <option>Active</option><option>Offline</option><option>Registered</option>
                <option>Locked</option><option>Maintenance</option><option>Error</option>
            </select>
        </div>
        <span style="font-size:12px;color:#888">Click row to edit / change status</span>
    </div>
    <div id="terminals-table-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
        <div style="padding:32px;text-align:center;color:#888">Loading...</div>
    </div>
    <div id="terminals-pagination" style="display:flex;gap:6px;margin-top:10px;justify-content:center"></div>
</div>

<!-- COMMANDS tab -->
<div id="tab-commands" class="tab-content" style="display:none">
    <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <select id="cmd-status" onchange="loadCommands()"
                style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
            <option value="">All Statuses</option>
            <option>Queued</option><option>Dispatched</option><option>Running</option>
            <option>Success</option><option>Failed</option><option>Retrying</option>
            <option>Cancelled</option><option>RolledBack</option><option>Expired</option>
        </select>
        <select id="cmd-type" onchange="loadCommands()"
                style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
            <option value="">All Types</option>
            <option>NsoSetup</option><option>FyClose</option>
            <option>TimeSyncTest</option><option>TimeSyncProd</option>
            <option>Rollback</option><option>AgentUpdate</option>
        </select>
    </div>
    <div id="commands-table-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
        <div style="padding:32px;text-align:center;color:#888">Loading...</div>
    </div>
    <div id="commands-pagination" style="display:flex;gap:6px;margin-top:10px;justify-content:center"></div>
</div>

<!-- FY JOBS tab -->
<div id="tab-fyjobs" class="tab-content" style="display:none">
    <div id="fyjobs-wrap"></div>
</div>

<!-- PACKAGES tab -->
<div id="tab-packages" class="tab-content" style="display:none">
    <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
        <button onclick="showCreatePackage()"
                style="padding:7px 16px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer">
            + Add Package
        </button>
    </div>
    <div id="packages-wrap"></div>
</div>

<!-- HEARTBEATS tab -->
<div id="tab-heartbeats" class="tab-content" style="display:none">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
        <span style="font-size:13px;color:#888">Live heartbeat feed — last 50 per page</span>
        <button onclick="purgeHeartbeats()"
                style="padding:6px 14px;background:#FCEBEB;color:#A32D2D;border:1px solid #F5B8B8;border-radius:6px;font-size:12px;cursor:pointer">
            🗑 Purge Old (>30 days)
        </button>
    </div>
    <div id="heartbeats-wrap"></div>
    <div id="heartbeats-pagination" style="display:flex;gap:6px;margin-top:10px;justify-content:center"></div>
</div>

<!-- AUDIT tab -->
<div id="tab-audit" class="tab-content" style="display:none">
    <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <input id="audit-action" placeholder="Action…" oninput="loadAudit()"
               style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
        <input id="audit-entity" placeholder="Entity type…" oninput="loadAudit()"
               style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
        <input id="audit-user" placeholder="User…" oninput="loadAudit()"
               style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
    </div>
    <div id="audit-wrap" style="background:#0F0F0F;border-radius:10px;overflow:hidden">
        <div style="padding:14px 16px;border-bottom:1px solid #1A1A1A;display:flex;justify-content:space-between">
            <span style="font-family:monospace;font-size:12px;color:#72D3A6">// RetailTMS Audit Log</span>
            <span id="audit-count" style="font-family:monospace;font-size:11px;color:#555"></span>
        </div>
        <div id="audit-rows" style="padding:10px 16px;max-height:500px;overflow-y:auto;font-family:monospace;font-size:12px"></div>
    </div>
    <div id="audit-pagination" style="display:flex;gap:6px;margin-top:10px;justify-content:center"></div>
</div>

@section Scripts {
<script>
// ── State ────────────────────────────────────────────────────────────────────
let storesPage = 1, terminalsPage = 1, commandsPage = 1;
let heartbeatsPage = 1, auditPage = 1;
const statusColors = {
    Active:'#3B6D11', Online:'#3B6D11', Success:'#3B6D11', Completed:'#3B6D11',
    Offline:'#A32D2D', Failed:'#A32D2D', Error:'#A32D2D', Locked:'#A32D2D',
    Queued:'#854F0B', Running:'#854F0B', Dispatched:'#854F0B', Retrying:'#854F0B',
    Pending:'#6C757D', Inactive:'#6C757D', Cancelled:'#6C757D', Registered:'#185FA5',
    Maintenance:'#185FA5', Paused:'#185FA5',
};
const statusBgs = {
    Active:'#EAF3DE', Online:'#EAF3DE', Success:'#EAF3DE', Completed:'#EAF3DE',
    Offline:'#FCEBEB', Failed:'#FCEBEB', Error:'#FCEBEB', Locked:'#FCEBEB',
    Queued:'#FAEEDA', Running:'#FAEEDA', Dispatched:'#FAEEDA', Retrying:'#FAEEDA',
    Pending:'#F0F0F0', Inactive:'#F0F0F0', Cancelled:'#F0F0F0',
    Registered:'#E6F1FB', Maintenance:'#E6F1FB', Paused:'#E6F1FB',
};
function badge(status) {
    const c = statusColors[status]||'#555', b = statusBgs[status]||'#EEE';
    return `<span style="background:${b};color:${c};padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;white-space:nowrap">● ${status}</span>`;
}
function fmtDate(d) { if(!d) return '—'; const dt=new Date(d); return dt.toLocaleDateString()+' '+dt.toLocaleTimeString(); }
function fmtSize(b) { if(!b) return '—'; if(b>1e6) return (b/1e6).toFixed(1)+' MB'; return (b/1e3).toFixed(0)+' KB'; }

// ── Toast ─────────────────────────────────────────────────────────────────────
function toast(msg, type='success') {
    const div = document.createElement('div');
    const colors = {success:'#EAF3DE|#3B6D11',error:'#FCEBEB|#A32D2D',info:'#E6F1FB|#185FA5'};
    const [bg,color] = (colors[type]||colors.info).split('|');
    div.style.cssText = `background:${bg};color:${color};padding:10px 16px;border-radius:8px;font-size:13px;font-weight:500;box-shadow:0 2px 12px rgba(0,0,0,.15);min-width:240px;border-left:3px solid ${color}`;
    div.textContent = msg;
    document.getElementById('toast-container').appendChild(div);
    setTimeout(() => div.remove(), 3500);
}

// ── Modal ─────────────────────────────────────────────────────────────────────
function showModal(title, body, buttons=[]) {
    document.getElementById('modal-title').textContent = title;
    document.getElementById('modal-body').innerHTML = body;
    const footer = document.getElementById('modal-footer');
    footer.innerHTML = '';
    buttons.forEach(b => {
        const btn = document.createElement('button');
        btn.textContent = b.label;
        btn.style.cssText = `padding:8px 18px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid transparent;background:${b.bg||'#185FA5'};color:${b.color||'#fff'}`;
        btn.onclick = b.action;
        footer.appendChild(btn);
    });
    const ov = document.getElementById('modal-overlay');
    ov.style.display = 'flex';
}
function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(id) {
    document.querySelectorAll('.tab-btn').forEach(b => {
        const on = b.dataset.tab === id;
        b.style.color = on ? '#185FA5' : '#888';
        b.style.fontWeight = on ? '600' : '400';
        b.style.borderBottomColor = on ? '#185FA5' : 'transparent';
    });
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    document.getElementById('tab-' + id).style.display = 'block';
    const loaders = { stores: loadStores, terminals: loadTerminals, commands: loadCommands,
        fyjobs: loadFYJobs, packages: loadPackages, heartbeats: loadHeartbeats, audit: loadAudit };
    loaders[id]?.();
}

function pagination(total, current, pageSize, onPage) {
    const pages = Math.ceil(total / pageSize);
    if (pages <= 1) return '';
    let html = '';
    for (let i=1; i<=pages; i++) {
        const active = i===current;
        html += `<button onclick="(${onPage})(${i})" style="padding:4px 10px;font-size:12px;border-radius:5px;border:1px solid ${active?'#185FA5':'#DDD'};background:${active?'#185FA5':'#fff'};color:${active?'#fff':'#555'};cursor:pointer">${i}</button>`;
    }
    return html;
}

// ══════════════════════════════════════════════════════════════════════════════
// SUMMARY
// ══════════════════════════════════════════════════════════════════════════════
async function loadSummary() {
    const d = await fetch('/Admin/Summary').then(r=>r.json());
    document.getElementById('sum-stores').textContent   = d.stores.total;
    document.getElementById('sum-online').textContent   = d.terminals.online;
    document.getElementById('sum-commands').textContent = d.commands.total;
    document.getElementById('sum-failed').textContent   = d.commands.failed;
    document.getElementById('sum-packages').textContent = d.packages.active + ' active';
    document.getElementById('sum-hb').textContent       = d.heartbeats.last24h;
}

// ══════════════════════════════════════════════════════════════════════════════
// STORES
// ══════════════════════════════════════════════════════════════════════════════
async function loadStores(p) {
    if(p) storesPage = p;
    const search = document.getElementById('store-search')?.value || '';
    const region = document.getElementById('store-region')?.value || '';
    const status = document.getElementById('store-status')?.value || '';
    const params = new URLSearchParams({ search, region, status, page: storesPage, pageSize: 20 });
    const d = await fetch('/Admin/Stores?' + params).then(r=>r.json());

    const tbody = d.items.map(s => `
        <tr style="border-bottom:1px solid #F0F0F0;cursor:pointer" onclick="editStore('${s.storeId}')">
            <td style="padding:9px 12px;font-family:monospace;font-size:12px;font-weight:600;color:#1F3864">${s.storeCode}</td>
            <td style="padding:9px 12px;font-size:13px">${s.storeName}</td>
            <td style="padding:9px 12px"><span style="background:#EEE;color:#555;padding:2px 7px;border-radius:4px;font-size:11px">${s.region}</span></td>
            <td style="padding:9px 12px;font-size:12px;color:#888">${s.zone}</td>
            <td style="padding:9px 12px">${badge(s.status)}</td>
            <td style="padding:9px 12px">${badge(s.fyCloseStatus)}</td>
            <td style="padding:9px 12px;text-align:center">
                <span style="font-size:11px;background:${s.activeTerminals>0?'#EAF3DE':'#F0F0F0'};color:${s.activeTerminals>0?'#3B6D11':'#888'};padding:2px 7px;border-radius:4px">
                    ${s.activeTerminals}/${s.terminalCount}
                </span>
            </td>
            <td style="padding:9px 12px;text-align:center">
                <span style="background:#F0F4FF;color:#185FA5;padding:2px 7px;border-radius:4px;font-size:11px">P${s.priority}</span>
            </td>
            <td style="padding:9px 12px" onclick="event.stopPropagation()">
                <div style="display:flex;gap:4px;white-space:nowrap">
                    <button onclick="setStoreStatus('${s.storeId}','${s.storeName}')"
                            style="padding:3px 8px;font-size:11px;background:#FAEEDA;color:#854F0B;border:none;border-radius:4px;cursor:pointer">Status</button>
                    <button onclick="editStore('${s.storeId}')"
                            style="padding:3px 8px;font-size:11px;background:#E6F1FB;color:#185FA5;border:none;border-radius:4px;cursor:pointer">Edit</button>
                    <button onclick="deleteStore('${s.storeId}','${s.storeName}')"
                            style="padding:3px 8px;font-size:11px;background:#FCEBEB;color:#A32D2D;border:none;border-radius:4px;cursor:pointer">Delete</button>
                </div>
            </td>
        </tr>`).join('');

    document.getElementById('stores-table-wrap').innerHTML = `
        <table style="width:100%;border-collapse:collapse">
            <thead>
                <tr style="background:#F8F9FA;border-bottom:2px solid #E8E8E8">
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase;letter-spacing:.05em">Code</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">Name</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">Region</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">Zone</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">Status</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">FY Status</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:center;text-transform:uppercase">Terminals</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:center;text-transform:uppercase">Priority</th>
                    <th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase">Actions</th>
                </tr>
            </thead>
            <tbody>${tbody}</tbody>
        </table>
        <div style="padding:8px 12px;border-top:1px solid #F0F0F0;font-size:12px;color:#888">${d.total} stores total</div>`;
    document.getElementById('stores-pagination').innerHTML =
        pagination(d.total, storesPage, 20, 'loadStores');
}

async function editStore(id) {
    const s = await fetch('/Admin/Stores/' + id).then(r=>r.json());
    showModal('Edit Store — ' + s.storeCode, `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Store Code</label>
                <input id="e-storeCode" value="${s.storeCode}" disabled style="padding:7px 10px;border:1px solid #EEE;border-radius:6px;font-size:13px;width:100%;background:#F8F9FA"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Store Name *</label>
                <input id="e-storeName" value="${s.storeName||''}" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Region *</label>
                <select id="e-region" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%;background:#fff">
                    ${['North','South','East','West','Central'].map(r=>`<option ${s.region===r?'selected':''}>${r}</option>`).join('')}
                </select></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Zone *</label>
                <input id="e-zone" value="${s.zone||''}" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Priority</label>
                <select id="e-priority" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%;background:#fff">
                    ${[1,2,3].map(p=>`<option value="${p}" ${s.priority===p?'selected':''}>P${p} — ${p===1?'High':p===2?'Normal':'Low'}</option>`).join('')}
                </select></div>
