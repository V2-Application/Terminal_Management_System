                ${[['Total',j.totalStores||0,'#212529','#F8F9FA'],['Completed',j.completedStores,'#3B6D11','#EAF3DE'],['Failed',j.failedStores,'#A32D2D','#FCEBEB'],['Offline',j.offlineStores,'#5F5E5A','#F1EFE8'],['Progress',j.completionPct+'%','#185FA5','#E6F1FB']].map(([l,v,c,b])=>
                    `<div style="background:${b};border-radius:6px;padding:8px;text-align:center"><div style="font-size:10px;color:${c};text-transform:uppercase;letter-spacing:.05em">${l}</div><div style="font-size:20px;font-weight:700;color:${c};font-family:monospace">${v}</div></div>`
