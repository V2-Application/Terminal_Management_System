                </div>
            </td>
        </tr>`).join('');
    document.getElementById('terminals-table-wrap').innerHTML = `
        <table style="width:100%;border-collapse:collapse">
            <thead><tr style="background:#F8F9FA;border-bottom:2px solid #E8E8E8">
                ${['Terminal','Store','Machine','IP','Status','Agent v.','Disk','Last HB','Primary','Actions'].map(h=>`<th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap">${h}</th>`).join('')}
            </tr></thead>
            <tbody>${tbody}</tbody>
        </table>
        <div style="padding:8px 12px;border-top:1px solid #F0F0F0;font-size:12px;color:#888">${d.total} terminals total</div>`;
    document.getElementById('terminals-pagination').innerHTML =
        pagination(d.total, terminalsPage, 20, 'loadTerminals');
}

