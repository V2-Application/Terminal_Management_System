                `<button data-val="${s}" onclick="selectStatus(this,'fy-job-status-btns')"
                 style="padding:9px 20px;border-radius:8px;border:2px solid ${statusColors[s]||'#DDD'};background:#fff;color:${statusColors[s]||'#555'};font-size:13px;cursor:pointer;font-weight:500;min-width:100px">${s}</button>`
            ).join('')}
        </div>`,
    [{label:'Cancel',bg:'#F0F0F0',color:'#555',action:closeModal},{label:'Apply',action:async()=>{
        const s=document.querySelector('#fy-job-status-btns .selected-status')?.dataset.val;
        if(!s){toast('Select a status','error');return;}
        const res=await fetch('/Admin/FYJobs/'+id+'/status',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:s})}).then(r=>r.json());
        if(res.success){closeModal();toast('FY Job status → '+s+' ✓');loadFYJobs();}else toast(res.error,'error');
    }}]);
}

// ══════════════════════════════════════════════════════════════════════════════
// PACKAGES
// ══════════════════════════════════════════════════════════════════════════════
async function loadPackages(){
    const items=await fetch('/Admin/Packages').then(r=>r.json());
    const rows=items.map(p=>`
        <tr style="border-bottom:1px solid #F0F0F0">
            <td style="padding:9px 12px;font-size:13px;font-weight:600;color:#1F3864">${p.packageName}</td>
            <td style="padding:9px 12px"><span style="background:#E6F1FB;color:#185FA5;padding:2px 7px;border-radius:4px;font-size:11px">${p.stepType}</span></td>
            <td style="padding:9px 12px;font-family:monospace;font-size:12px">${p.version}</td>
            <td style="padding:9px 12px;font-size:12px;color:#888">${p.dllVersion||'—'}</td>
            <td style="padding:9px 12px;font-size:12px;color:#888">${fmtSize(p.fileSize)}</td>
            <td style="padding:9px 12px;font-size:11px;color:#888">${p.fyYear||'—'}</td>
            <td style="padding:9px 12px">
                ${p.isActive?'<span style="background:#EAF3DE;color:#3B6D11;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600">● Active</span>':
                  p.isRollbackPackage?'<span style="background:#FAEEDA;color:#854F0B;padding:2px 8px;border-radius:4px;font-size:11px">Rollback</span>':
                  '<span style="background:#F0F0F0;color:#888;padding:2px 8px;border-radius:4px;font-size:11px">Inactive</span>'}
            </td>
            <td style="padding:9px 12px;font-size:11px;color:#888">${p.uploadedAt?new Date(p.uploadedAt).toLocaleDateString():''}</td>
            <td style="padding:9px 12px">
                <div style="display:flex;gap:4px">
                    ${!p.isActive?`<button onclick="activatePkg('${p.packageId}')"
                            style="padding:3px 8px;font-size:11px;background:#EAF3DE;color:#3B6D11;border:none;border-radius:4px;cursor:pointer">Activate</button>`:''}
                    <button onclick="editPackage('${p.packageId}')"
                            style="padding:3px 8px;font-size:11px;background:#E6F1FB;color:#185FA5;border:none;border-radius:4px;cursor:pointer">Edit</button>
                    <button onclick="deletePkg('${p.packageId}','${p.packageName}')"
                            style="padding:3px 8px;font-size:11px;background:#FCEBEB;color:#A32D2D;border:none;border-radius:4px;cursor:pointer">Delete</button>
                </div>
            </td>
        </tr>`).join('');
    document.getElementById('packages-wrap').innerHTML=`
        <div style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
        <table style="width:100%;border-collapse:collapse">
            <thead><tr style="background:#F8F9FA;border-bottom:2px solid #E8E8E8">
                ${['Name','Step Type','Version','DLL Version','Size','FY Year','Status','Uploaded','Actions'].map(h=>`<th style="padding:10px 12px;font-size:11px;font-weight:600;color:#888;text-align:left;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap">${h}</th>`).join('')}
            </tr></thead>
            <tbody>${rows}</tbody>
        </table></div>`;
}

async function activatePkg(id){
    const res=await fetch('/Admin/Packages/'+id+'/activate',{method:'PATCH'}).then(r=>r.json());
    if(res.success){toast('Package activated ✓');loadPackages();}else toast(res.error,'error');
}

async function deletePkg(id,name){
    if(!confirm('Delete package "'+name+'"?')) return;
    const res=await fetch('/Admin/Packages/'+id,{method:'DELETE'}).then(r=>r.json());
    if(res.success){toast('Package deleted');loadPackages();}else toast(res.error,'error');
}

function showCreatePackage(){
    showModal('Add Script Package',`
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Package Name *</label>
                <input id="p-name" placeholder="FY2025-DLLs-v4" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Step Type *</label>
                <select id="p-step" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%;background:#fff">
                    <option>FY_CLOSE</option><option>NSO_SETUP</option>
                    <option>TIME_SYNC_TEST</option><option>TIME_SYNC_PROD</option>
                </select></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Version *</label>
                <input id="p-version" placeholder="FY2025-v4" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">DLL Version</label>
                <input id="p-dllver" placeholder="6.3.4000.1234" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">FY Year</label>
                <input id="p-fy" value="FY2025" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">SHA-256 Hash *</label>
                <input id="p-hash" placeholder="a3f8c2d1e9b4..." style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div style="grid-column:span 2"><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Storage Path *</label>
                <input id="p-path" placeholder="C:\\RetailTMS\\Packages\\FY2025-v4.zip" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div style="display:flex;gap:12px;grid-column:span 2">
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="p-active"> Set as Active for this FY Year
                </label>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="p-rollback"> Rollback Package
                </label>
            </div>
        </div>`,
    [{label:'Cancel',bg:'#F0F0F0',color:'#555',action:closeModal},{label:'Create Package',action:async()=>{
        const res=await fetch('/Admin/Packages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
            packageName:document.getElementById('p-name').value,
            stepType:document.getElementById('p-step').value,
            version:document.getElementById('p-version').value,
            dllVersion:document.getElementById('p-dllver').value||null,
            fileSize:0,
            sha256Hash:document.getElementById('p-hash').value,
            storagePath:document.getElementById('p-path').value,
            fyYear:document.getElementById('p-fy').value,
            isActive:document.getElementById('p-active').checked,
            isRollbackPackage:document.getElementById('p-rollback').checked,
        })}).then(r=>r.json());
        if(res.success){closeModal();toast('Package created ✓');loadPackages();loadSummary();}
        else toast(res.error||'Error','error');
    }}]);
}

async function editPackage(id){
    const all=await fetch('/Admin/Packages').then(r=>r.json());
    const p=all.find(x=>x.packageId===id)||{};
    showModal('Edit Package — '+p.packageName,`
        <div style="display:flex;flex-direction:column;gap:10px">
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Package Name</label>
                <input id="ep-name" value="${p.packageName||''}" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Version</label>
                <input id="ep-ver" value="${p.version||''}" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div><label style="font-size:12px;font-weight:600;color:#555;display:block;margin-bottom:4px">Storage Path</label>
                <input id="ep-path" value="${p.storagePath||''}" style="padding:7px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;width:100%"></div>
            <div style="display:flex;gap:16px">
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="ep-active" ${p.isActive?'checked':''}> Is Active
                </label>
                <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="ep-rollback" ${p.isRollbackPackage?'checked':''}> Is Rollback
                </label>
            </div>
        </div>`,
    [{label:'Cancel',bg:'#F0F0F0',color:'#555',action:closeModal},{label:'Save',action:async()=>{
        const res=await fetch('/Admin/Packages/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({
            packageName:document.getElementById('ep-name').value,
            stepType:p.stepType,version:document.getElementById('ep-ver').value,
            dllVersion:p.dllVersion,fileSize:p.fileSize,sha256Hash:p.sha256Hash,
            storagePath:document.getElementById('ep-path').value,fyYear:p.fyYear,
            isActive:document.getElementById('ep-active').checked,
            isRollbackPackage:document.getElementById('ep-rollback').checked,
        })}).then(r=>r.json());
        if(res.success){closeModal();toast('Package updated ✓');loadPackages();}else toast(res.error,'error');
    }}]);
}

// ══════════════════════════════════════════════════════════════════════════════
// HEARTBEATS
// ══════════════════════════════════════════════════════════════════════════════
async function loadHeartbeats(p){
    if(p) heartbeatsPage=p;
    const d=await fetch('/Admin/Heartbeats?page='+heartbeatsPage+'&pageSize=50').then(r=>r.json());
    const rows=d.items.map(h=>`
        <div style="display:flex;gap:14px;padding:5px 16px;border-bottom:1px solid #1A1A1A;font-size:12px;font-family:monospace">
            <span style="color:#378ADD;min-width:145px;white-space:nowrap">${new Date(h.receivedAt).toLocaleString()}</span>
            <span style="color:#C3E88D;min-width:80px">${h.terminalCode}</span>
            <span style="color:#72D3A6;min-width:60px">${h.storeCode}</span>
            <span style="color:${h.status==='ACTIVE'?'#97C459':'#F09595'};min-width:60px">${h.status}</span>
            <span style="color:${(h.diskFreeGB||0)<5?'#F09595':'#9FA8A3'};min-width:60px">${h.diskFreeGB?h.diskFreeGB.toFixed(0)+' GB':'—'}</span>
            <span style="color:${h.posProcessRunning?'#97C459':'#555'}">${h.posProcessRunning?'POS:ON':'POS:OFF'}</span>
            <span style="color:#555;min-width:50px">${h.agentVersion||'—'}</span>
        </div>`).join('');
    document.getElementById('heartbeats-wrap').innerHTML=`
        <div style="background:#0F0F0F;border-radius:10px;overflow:hidden">
            <div style="padding:10px 16px;border-bottom:1px solid #1A1A1A;display:flex;justify-content:space-between;align-items:center">
                <span style="font-family:monospace;font-size:12px;color:#72D3A6">// Heartbeat Feed</span>
                <span style="font-family:monospace;font-size:11px;color:#555">${d.total} total records</span>
            </div>
            <div style="padding:4px 0;max-height:500px;overflow-y:auto">${rows||'<div style="padding:20px 16px;color:#555;font-family:monospace;font-size:12px">No heartbeats yet</div>'}</div>
        </div>`;
    document.getElementById('heartbeats-pagination').innerHTML=pagination(d.total,heartbeatsPage,50,'loadHeartbeats');
}

async function purgeHeartbeats(){
    if(!confirm('Purge all heartbeats older than 30 days?')) return;
    const res=await fetch('/Admin/Heartbeats/purge',{method:'DELETE',headers:{'Content-Type':'application/json'},body:JSON.stringify({olderThanDays:30})}).then(r=>r.json());
    if(res.success){toast('Purged '+res.deleted+' records');loadHeartbeats();loadSummary();}
}

// ══════════════════════════════════════════════════════════════════════════════
// AUDIT LOGS
// ══════════════════════════════════════════════════════════════════════════════
async function loadAudit(p){
    if(p) auditPage=p;
    const params=new URLSearchParams({
        action:document.getElementById('audit-action')?.value||'',
        entityType:document.getElementById('audit-entity')?.value||'',
        userId:document.getElementById('audit-user')?.value||'',
        page:auditPage,pageSize:50,
    });
    const d=await fetch('/Admin/AuditLogs?'+params).then(r=>r.json());
    document.getElementById('audit-count').textContent=d.total+' entries';
    const rows=d.items.map(a=>`
        <div style="display:flex;gap:14px;margin-bottom:3px">
            <span style="color:#378ADD;white-space:nowrap;min-width:145px;font-size:12px">${new Date(a.timestamp).toLocaleString()}</span>
            <span style="color:#72D3A6;min-width:100px;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${(a.userId||'').substring(0,20)}</span>
            <span style="color:${a.result==='SUCCESS'?'#97C459':'#F09595'};min-width:200px;font-size:12px;white-space:nowrap">${a.action}</span>
            <span style="color:#9FA8A3;font-size:12px">${a.entityType}/${a.entityId} ${a.details?'— '+(a.details.length>60?a.details.substring(0,60)+'…':a.details):''}</span>
        </div>`).join('');
    document.getElementById('audit-rows').innerHTML=rows||'<div style="color:#555">No entries</div>';
    document.getElementById('audit-pagination').innerHTML=pagination(d.total,auditPage,50,'loadAudit');
}

// ── Init ──────────────────────────────────────────────────────────────────────
window.addEventListener('load', () => {
    loadSummary();
    switchTab('stores');
    setInterval(loadSummary, 30000);
});
</script>
}
