function pickStatus(btn,group){
  document.querySelectorAll('#'+group+' button').forEach(b=>{
    b.classList.remove('picked');b.style.fontWeight='400';
    const c=SC[b.dataset.v]?.split('|');
    if(c){b.style.background='#fff';}
  });
  btn.classList.add('picked');btn.style.fontWeight='700';
  const c=SC[btn.dataset.v]?.split('|');
  if(c)btn.style.background=c[0];
}

