@{
    ViewData["Title"] = "Admin — Configuration & CRUD";
}
<style>
.tab-btn { padding:10px 16px;border:none;background:transparent;cursor:pointer;font-size:13px;font-weight:500;color:#888;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s }
.tab-btn.active { color:#185FA5;border-bottom-color:#185FA5;font-weight:600 }
.tab-btn:hover { color:#185FA5 }
.tab-pane { display:none }
.tab-pane.active { display:block }
.crud-table { width:100%;border-collapse:collapse }
.crud-table th { padding:9px 12px;font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.05em;text-align:left;background:#F8F9FA;border-bottom:2px solid #E8E8E8;white-space:nowrap }
.crud-table td { padding:8px 12px;font-size:13px;border-bottom:1px solid #F0F0F0;vertical-align:middle }
.crud-table tr:hover td { background:#F5F8FF;cursor:pointer }
.status-pill { padding:2px 9px;border-radius:4px;font-size:11px;font-weight:600;display:inline-block }
.btn-action { padding:3px 9px;font-size:11px;border:none;border-radius:4px;cursor:pointer;font-weight:500 }
.btn-action:hover { opacity:.85 }
.modal-mask { display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center }
.modal-mask.open { display:flex }
.modal-box { background:#fff;border-radius:12px;padding:24px;width:520px;max-width:92vw;max-height:85vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.2) }
.form-row { display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px }
.form-field label { display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px }
.form-field input,.form-field select { width:100%;padding:8px 10px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;background:#fff;outline:none }
.form-field input:focus,.form-field select:focus { border-color:#185FA5 }
.toast-wrap { position:fixed;top:56px;right:16px;z-index:2000;display:flex;flex-direction:column;gap:8px }
.toast { padding:10px 16px;border-radius:8px;font-size:13px;font-weight:500;box-shadow:0 2px 12px rgba(0,0,0,.15);min-width:220px;border-left:3px solid }
.toast.ok  { background:#EAF3DE;color:#3B6D11;border-color:#639922 }
.toast.err { background:#FCEBEB;color:#A32D2D;border-color:#E74C3C }
.toast.inf { background:#E6F1FB;color:#185FA5;border-color:#185FA5 }
.kpi-grid { display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin:12px 0 }
.kpi-card { border-radius:7px;padding:10px;text-align:center;border:1px solid #EEE }
.kpi-card .kpi-label { font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px }
.kpi-card .kpi-val { font-size:20px;font-weight:700;font-family:monospace }
</style>

<!-- Toast container -->
<div class="toast-wrap" id="toasts"></div>

<!-- Modal -->
<div class="modal-mask" id="modal">
  <div class="modal-box">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <h3 id="modal-title" style="font-size:16px;font-weight:700;color:#1F3864;margin:0"></h3>
      <button onclick="closeModal()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#888;line-height:1">×</button>
    </div>
    <div id="modal-body"></div>
    <div id="modal-footer" style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px;padding-top:12px;border-top:1px solid #EEE"></div>
  </div>
</div>

<!-- KPI Bar -->
<div class="kpi-grid">
  <div class="kpi-card" style="background:#F8F9FA"><div class="kpi-label" style="color:#888">Stores</div><div class="kpi-val" id="k-stores" style="color:#1F3864">—</div></div>
  <div class="kpi-card" style="background:#EAF3DE"><div class="kpi-label" style="color:#3B6D11">Online</div><div class="kpi-val" id="k-online" style="color:#3B6D11">—</div></div>
  <div class="kpi-card" style="background:#FAEEDA"><div class="kpi-label" style="color:#854F0B">Commands</div><div class="kpi-val" id="k-cmds" style="color:#854F0B">—</div></div>
  <div class="kpi-card" style="background:#FCEBEB"><div class="kpi-label" style="color:#A32D2D">Failed</div><div class="kpi-val" id="k-failed" style="color:#A32D2D">—</div></div>
  <div class="kpi-card" style="background:#E6F1FB"><div class="kpi-label" style="color:#185FA5">Packages</div><div class="kpi-val" id="k-pkgs" style="color:#185FA5">—</div></div>
  <div class="kpi-card" style="background:#F0F0F0"><div class="kpi-label" style="color:#555">HB 24h</div><div class="kpi-val" id="k-hb" style="color:#555">—</div></div>
</div>

<!-- Tab bar -->
<div style="display:flex;gap:0;border-bottom:2px solid #E8E8E8;margin-bottom:12px;overflow-x:auto">
  <button class="tab-btn active" onclick="showTab('stores')">🏪 Stores</button>
  <button class="tab-btn" onclick="showTab('terminals')">🖥 Terminals</button>
  <button class="tab-btn" onclick="showTab('commands')">⚙ Commands</button>
  <button class="tab-btn" onclick="showTab('fyjobs')">📅 FY Jobs</button>
  <button class="tab-btn" onclick="showTab('packages')">📦 Packages</button>
  <button class="tab-btn" onclick="showTab('heartbeats')">💓 Heartbeats</button>
  <button class="tab-btn" onclick="showTab('audit')">📋 Audit Logs</button>
</div>

<!-- Stores pane -->
<div class="tab-pane active" id="pane-stores">
  <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;flex-wrap:wrap">
    <input id="s-search" placeholder="Search code / name…" oninput="loadStores()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:180px"/>
    <select id="s-region" onchange="loadStores()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
      <option value="">All Regions</option>
      <option>North</option><option>South</option><option>East</option><option>West</option><option>Central</option>
    </select>
    <select id="s-status" onchange="loadStores()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
      <option value="">All Statuses</option><option>Active</option><option>Inactive</option><option>Decommissioned</option>
    </select>
    <div style="flex:1"></div>
    <button onclick="openCreateStore()" style="padding:7px 14px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer;font-weight:600">+ Add Store</button>
  </div>
  <div id="stores-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#888">Loading...</div>
  </div>
  <div id="stores-pages" style="display:flex;gap:5px;justify-content:center;margin-top:10px"></div>
</div>

<!-- Terminals pane -->
<div class="tab-pane" id="pane-terminals">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
    <input id="t-search" placeholder="Search terminal / machine…" oninput="loadTerminals()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:200px"/>
    <select id="t-status" onchange="loadTerminals()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
      <option value="">All Statuses</option>
      <option>Active</option><option>Offline</option><option>Registered</option><option>Locked</option><option>Maintenance</option><option>Error</option>
    </select>
  </div>
  <div id="terminals-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#888">Loading...</div>
  </div>
  <div id="terminals-pages" style="display:flex;gap:5px;justify-content:center;margin-top:10px"></div>
</div>

<!-- Commands pane -->
<div class="tab-pane" id="pane-commands">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
    <select id="c-status" onchange="loadCommands()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
      <option value="">All Statuses</option>
      <option>Queued</option><option>Dispatched</option><option>Running</option>
      <option>Success</option><option>Failed</option><option>Retrying</option>
      <option>Cancelled</option><option>RolledBack</option><option>Expired</option>
    </select>
    <select id="c-type" onchange="loadCommands()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px">
      <option value="">All Types</option>
      <option>NsoSetup</option><option>FyClose</option><option>TimeSyncTest</option><option>TimeSyncProd</option><option>Rollback</option>
    </select>
  </div>
  <div id="commands-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#888">Loading...</div>
  </div>
  <div id="commands-pages" style="display:flex;gap:5px;justify-content:center;margin-top:10px"></div>
</div>

<!-- FY Jobs pane -->
<div class="tab-pane" id="pane-fyjobs">
  <div id="fyjobs-wrap"><div style="padding:40px;text-align:center;color:#888">Loading...</div></div>
</div>

<!-- Packages pane -->
<div class="tab-pane" id="pane-packages">
  <div style="display:flex;justify-content:flex-end;margin-bottom:10px">
    <button onclick="openCreatePackage()" style="padding:7px 14px;background:#185FA5;color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer;font-weight:600">+ Add Package</button>
  </div>
  <div id="packages-wrap" style="background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#888">Loading...</div>
  </div>
</div>

<!-- Heartbeats pane -->
<div class="tab-pane" id="pane-heartbeats">
  <div style="display:flex;justify-content:space-between;margin-bottom:10px">
    <span style="font-size:13px;color:#888">Last heartbeat feed — real-time</span>
    <button onclick="purgeHB()" style="padding:5px 12px;background:#FCEBEB;color:#A32D2D;border:1px solid #F5B8B8;border-radius:6px;font-size:12px;cursor:pointer">🗑 Purge &gt;30 days</button>
  </div>
  <div id="hb-wrap" style="background:#0F0F0F;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#555;font-family:monospace">Loading...</div>
  </div>
  <div id="hb-pages" style="display:flex;gap:5px;justify-content:center;margin-top:10px"></div>
</div>

<!-- Audit pane -->
<div class="tab-pane" id="pane-audit">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
    <input id="a-action" placeholder="Action…" oninput="loadAudit()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
    <input id="a-entity" placeholder="Entity type…" oninput="loadAudit()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
    <input id="a-user" placeholder="User…" oninput="loadAudit()" style="padding:6px 10px;border:1px solid #DDD;border-radius:6px;font-size:13px;width:150px"/>
  </div>
  <div id="audit-wrap" style="background:#0F0F0F;border-radius:10px;overflow:hidden">
    <div style="padding:40px;text-align:center;color:#555;font-family:monospace">Loading...</div>
  </div>
  <div id="audit-pages" style="display:flex;gap:5px;justify-content:center;margin-top:10px"></div>
</div>

<script>
/* ── helpers ─────────────────────────────────────────────────────────────── */
const SC = {Active:'#EAF3DE|#3B6D11',Online:'#EAF3DE|#3B6D11',Success:'#EAF3DE|#3B6D11',Completed:'#EAF3DE|#3B6D11',
  Offline:'#FCEBEB|#A32D2D',Failed:'#FCEBEB|#A32D2D',Error:'#FCEBEB|#A32D2D',Locked:'#FCEBEB|#A32D2D',
  Queued:'#FAEEDA|#854F0B',Running:'#FAEEDA|#854F0B',Dispatched:'#FAEEDA|#854F0B',Retrying:'#FAEEDA|#854F0B',
  Registered:'#E6F1FB|#185FA5',Maintenance:'#E6F1FB|#185FA5',Paused:'#E6F1FB|#185FA5',
  Pending:'#F0F0F0|#6C757D',Inactive:'#F0F0F0|#6C757D',Cancelled:'#F0F0F0|#6C757D'};

function pill(s){
  const [bg,c]=(SC[s]||'#EEE|#555').split('|');
  return `<span class="status-pill" style="background:${bg};color:${c}">● ${s||'?'}</span>`;
}
function btn(label,bg,color,onclick){
  return `<button class="btn-action" style="background:${bg};color:${color}" onclick="${onclick}">${label}</button>`;
}
function d(v){return v?new Date(v).toLocaleString():'—';}
function ds(v){return v?new Date(v).toLocaleDateString():'—';}

function toast(msg,type='ok'){
  const el=document.createElement('div');
  el.className='toast '+type;
  el.textContent=msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(()=>el.remove(),3500);
}

function pages(total,cur,size,fn){
  const n=Math.ceil(total/size); if(n<=1)return'';
  let h='';
  for(let i=1;i<=n;i++) h+=`<button onclick="${fn}(${i})" style="padding:3px 9px;font-size:12px;border-radius:4px;border:1px solid ${i===cur?'#185FA5':'#DDD'};background:${i===cur?'#185FA5':'#fff'};color:${i===cur?'#fff':'#555'};cursor:pointer">${i}</button>`;
  return h;
}

async function api(url,method='GET',body=null){
  try{
    const opts={method,headers:{}};
    if(body){opts.headers['Content-Type']='application/json';opts.body=JSON.stringify(body);}
    const r=await fetch(url,opts);
    if(!r.ok) throw new Error('HTTP '+r.status);
    return await r.json();
  }catch(e){
    toast('Error: '+e.message,'err');
    return null;
  }
}

/* ── modal ──────────────────────────────────────────────────────────────── */
function openModal(title,body,buttons=[]){
  document.getElementById('modal-title').textContent=title;
  document.getElementById('modal-body').innerHTML=body;
  const f=document.getElementById('modal-footer');
  f.innerHTML='';
  buttons.forEach(b=>{
    const el=document.createElement('button');
    el.textContent=b.label;
    el.style.cssText=`padding:8px 18px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;border:none;background:${b.bg||'#185FA5'};color:${b.c||'#fff'}`;
    el.onclick=b.fn;
    f.appendChild(el);
  });
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}

/* ── tabs ────────────────────────────────────────────────────────────────── */
const loaders = {stores:loadStores,terminals:loadTerminals,commands:loadCommands,
  fyjobs:loadFYJobs,packages:loadPackages,heartbeats:loadHB,audit:loadAudit};

function showTab(name){
  document.querySelectorAll('.tab-btn').forEach((b,i)=>{
    const tabs=['stores','terminals','commands','fyjobs','packages','heartbeats','audit'];
    b.classList.toggle('active',tabs[i]===name);
  });
  document.querySelectorAll('.tab-pane').forEach(p=>{
    p.classList.toggle('active',p.id==='pane-'+name);
  });
  if(loaders[name]) loaders[name](1);
}

/* ── KPI summary ─────────────────────────────────────────────────────────── */
async function loadKPI(){
  const d=await api('/Admin/Summary');
  if(!d)return;
  document.getElementById('k-stores').textContent  = d.stores?.total??'?';
  document.getElementById('k-online').textContent  = d.terminals?.online??'?';
  document.getElementById('k-cmds').textContent    = d.commands?.total??'?';
  document.getElementById('k-failed').textContent  = d.commands?.failed??'?';
  document.getElementById('k-pkgs').textContent    = (d.packages?.active??'?')+' active';
  document.getElementById('k-hb').textContent      = d.heartbeats?.last24h??'?';
}

/* ══ STORES ════════════════════════════════════════════════════════════════ */
let sPage=1;
async function loadStores(p=1){
  sPage=p;
  const search=document.getElementById('s-search')?.value||'';
  const region=document.getElementById('s-region')?.value||'';
  const status=document.getElementById('s-status')?.value||'';
  const q=new URLSearchParams({search,region,status,page:p,pageSize:20});
  const d=await api('/Admin/Stores?'+q);
  if(!d){document.getElementById('stores-wrap').innerHTML='<div style="padding:30px;text-align:center;color:#A32D2D">Failed to load — check app is running</div>';return;}

  const rows=d.items.map(s=>`
    <tr>
      <td onclick="editStore('${s.storeId}')" style="cursor:pointer"><span style="font-family:monospace;font-weight:600;font-size:12px;color:#1F3864">${s.storeCode}</span></td>
      <td onclick="editStore('${s.storeId}')" style="cursor:pointer">${s.storeName}</td>
      <td><span style="background:#EEE;color:#555;padding:2px 6px;border-radius:4px;font-size:11px">${s.region}</span></td>
      <td style="font-size:12px;color:#888">${s.zone}</td>
      <td>${pill(s.status)}</td>
      <td>${pill(s.fyCloseStatus)}</td>
      <td style="text-align:center;font-size:12px"><span style="background:${s.activeTerminals>0?'#EAF3DE':'#EEE'};color:${s.activeTerminals>0?'#3B6D11':'#888'};padding:2px 7px;border-radius:4px">${s.activeTerminals}/${s.terminalCount}</span></td>
      <td style="text-align:center"><span style="background:${s.priority===1?'#FCEBEB':s.priority===2?'#FAEEDA':'#F0F0F0'};color:${s.priority===1?'#A32D2D':s.priority===2?'#854F0B':'#555'};padding:2px 7px;border-radius:4px;font-size:11px">P${s.priority}</span></td>
      <td onclick="event.stopPropagation()" style="white-space:nowrap">
        ${btn('Status','#FAEEDA','#854F0B',`setStoreStatus('${s.storeId}','${s.storeName}')`)}
        ${btn('Edit','#E6F1FB','#185FA5',`editStore('${s.storeId}')`)}
        ${btn('Del','#FCEBEB','#A32D2D',`delStore('${s.storeId}','${s.storeName}')`)}
      </td>
    </tr>`).join('');

  document.getElementById('stores-wrap').innerHTML=`
    <table class="crud-table">
      <thead><tr><th>Code</th><th>Name</th><th>Region</th><th>Zone</th><th>Status</th><th>FY Status</th><th>Terminals</th><th>Priority</th><th>Actions</th></tr></thead>
      <tbody>${rows||'<tr><td colspan="9" style="text-align:center;padding:20px;color:#888">No stores found</td></tr>'}</tbody>
    </table>
    <div style="padding:7px 12px;border-top:1px solid #F0F0F0;font-size:12px;color:#888">${d.total} stores</div>`;
  document.getElementById('stores-pages').innerHTML=pages(d.total,sPage,20,'loadStores');
}

async function editStore(id){
  const s=await api('/Admin/Stores/'+id);
  if(!s)return;
  openModal('Edit Store — '+s.storeCode,`
    <div class="form-row">
      <div class="form-field"><label>Store Name *</label><input id="e-name" value="${s.storeName||''}"></div>
      <div class="form-field"><label>Region *</label>
        <select id="e-region">${['North','South','East','West','Central'].map(r=>`<option ${s.region===r?'selected':''}>${r}</option>`).join('')}</select></div>
      <div class="form-field"><label>Zone *</label><input id="e-zone" value="${s.zone||''}"></div>
      <div class="form-field"><label>Priority</label>
        <select id="e-pri">${[1,2,3].map(p=>`<option value="${p}" ${s.priority===p?'selected':''}>P${p} — ${p===1?'High':p===2?'Normal':'Low'}</option>`).join('')}</select></div>
      <div class="form-field"><label>Status</label>
        <select id="e-status">${['Active','Inactive','Decommissioned'].map(v=>`<option ${s.status===v?'selected':''}>${v}</option>`).join('')}</select></div>
      <div class="form-field"><label>FY Close Status</label>
        <select id="e-fystatus">${['Pending','Completed','Failed','Offline','Skipped'].map(v=>`<option ${s.fyCloseStatus===v?'selected':''}>${v}</option>`).join('')}</select></div>
      <div class="form-field"><label>Email</label><input id="e-email" value="${s.contactEmail||''}"></div>
      <div class="form-field"><label>Phone</label><input id="e-phone" value="${s.contactPhone||''}"></div>
    </div>`,
  [
    {label:'Cancel',bg:'#EEE',c:'#555',fn:closeModal},
    {label:'Save Changes',fn:async()=>{
      const r=await api('/Admin/Stores/'+id,'PUT',{
        storeCode:s.storeCode,
        storeName:document.getElementById('e-name').value,
        region:document.getElementById('e-region').value,
        zone:document.getElementById('e-zone').value,
        priority:+document.getElementById('e-pri').value,
        status:document.getElementById('e-status').value,
        contactEmail:document.getElementById('e-email').value,
        contactPhone:document.getElementById('e-phone').value
      });
      if(r?.success){closeModal();toast('Store saved ✓');loadStores(sPage);
        // also patch FY status
        const fy=document.getElementById('e-fystatus').value;
        if(fy!==s.fyCloseStatus) await api('/Admin/Stores/'+id+'/status','PATCH',{status:s.status,fyCloseStatus:fy});
        loadStores(sPage);loadKPI();
      }
    }}
  ]);
}

async function setStoreStatus(id,name){
  openModal('Change Status — '+name,`
    <div style="margin-bottom:14px">
      <div style="font-size:12px;font-weight:600;color:#555;margin-bottom:8px">Store Status</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap" id="ss-btns">
        ${['Active','Inactive','Decommissioned'].map(v=>`<button data-v="${v}" onclick="pickStatus(this,'ss-btns')" style="padding:6px 14px;border-radius:6px;border:1.5px solid ${SC[v]?.split('|')[1]||'#DDD'};background:#fff;color:${SC[v]?.split('|')[1]||'#555'};font-size:13px;cursor:pointer">${v}</button>`).join('')}
      </div>
    </div>
    <div>
      <div style="font-size:12px;font-weight:600;color:#555;margin-bottom:8px">FY Close Status</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap" id="fy-btns">
        ${['Pending','Completed','Failed','Offline','Skipped'].map(v=>`<button data-v="${v}" onclick="pickStatus(this,'fy-btns')" style="padding:6px 14px;border-radius:6px;border:1.5px solid ${SC[v]?.split('|')[1]||'#DDD'};background:#fff;color:${SC[v]?.split('|')[1]||'#555'};font-size:13px;cursor:pointer">${v}</button>`).join('')}
      </div>
    </div>`,
  [
