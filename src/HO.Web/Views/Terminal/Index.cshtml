@model IEnumerable<HO.Domain.Entities.Terminal>
@{
    ViewData["Title"] = "Terminal Master";
    var list = Model.ToList();
}
<div style="color:#888;font-size:13px;margin-bottom:12px">@list.Count terminals registered</div>
<div class="card">
    <div class="p-0">
        <table>
            <thead>
                <tr>
                    <th>Terminal</th><th>Store</th><th>Machine</th><th>IP Address</th>
                    <th>Status</th><th>Agent v.</th><th>Disk Free</th><th>Last Heartbeat</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in list)
            {
                var ts = t.Status.ToString() switch {
                    "Active"   => "background:#EAF3DE;color:#3B6D11",
                    "Offline"  => "background:#F1EFE8;color:#5F5E5A",
                    _          => "background:#F0F0F0;color:#6C757D"
                };
                <tr>
                    <td>
                        <span style="font-family:monospace;font-weight:600;font-size:12px">@t.TerminalCode</span>
                        @if (t.IsPrimary) { <span style="font-size:10px;background:#E6F1FB;color:#185FA5;padding:1px 5px;border-radius:3px;margin-left:4px">★</span> }
                    </td>
                    <td style="font-size:12px;color:#555">@(t.Store?.StoreCode ?? "—")</td>
                    <td style="font-size:12px;color:#888">@t.MachineName</td>
                    <td style="font-family:monospace;font-size:11px;color:#888">@(t.IpAddress ?? "—")</td>
                    <td><span style="@ts;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:500">@t.Status</span></td>
                    <td style="font-family:monospace;font-size:11px">@(t.AgentVersion ?? "—")</td>
                    <td style="font-size:12px;color:@(t.DiskFreeGB < 5 ? "#A32D2D" : "#3B6D11")">
                        @(t.DiskFreeGB.HasValue ? t.DiskFreeGB.Value.ToString("F0") + " GB" : "—")
                    </td>
                    <td style="font-size:11px;color:#888">
                        @if (t.LastHeartbeat.HasValue)
                        {
                            var ago = DateTime.UtcNow - t.LastHeartbeat.Value;
                            <span style="color:@(ago.TotalMinutes < 10?"#3B6D11":ago.TotalHours < 1?"#854F0B":"#A32D2D")">
                                @t.LastHeartbeat.Value.ToString("HH:mm dd-MMM")
                            </span>
                        }
                        else { <span>Never</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
