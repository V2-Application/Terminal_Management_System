@model IEnumerable<HO.Domain.Entities.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <span style="font-size:13px;color:#888">@ViewBag.Total total entries — immutable (INSERT only)</span>
    <span style="font-size:11px;color:#888;font-family:monospace">Page @ViewBag.Page of @ViewBag.Pages</span>
</div>

<div style="background:#0F0F0F;border-radius:10px;overflow:hidden">
    <div style="padding:10px 16px;border-bottom:1px solid #1A1A1A;display:flex;justify-content:space-between">
        <span style="font-family:monospace;font-size:12px;color:#72D3A6">// HO Audit Log</span>
        <span style="font-family:monospace;font-size:11px;color:#555">@Model.Count() entries shown</span>
    </div>
    <div style="padding:10px 16px;max-height:65vh;overflow-y:auto">
    @foreach (var log in Model)
    {
        <div style="display:flex;gap:14px;margin-bottom:4px;font-size:12px;font-family:monospace">
            <span style="color:#378ADD;white-space:nowrap;min-width:145px">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</span>
            <span style="color:#72D3A6;min-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(log.UserId.Length>15?log.UserId[..15]:log.UserId)</span>
            <span style="color:@(log.Result=="SUCCESS"?"#97C459":"#F09595");min-width:180px;white-space:nowrap">@log.Action</span>
            <span style="color:#9FA8A3">@log.EntityType/@log.EntityId @(log.Details != null ? "— " + (log.Details.Length>70?log.Details[..70]+"…":log.Details) : "")</span>
        </div>
    }
    @if (!Model.Any()) {
        <div style="font-family:monospace;font-size:12px;color:#555;padding:20px 0">// No audit entries yet</div>
    }
    </div>
</div>

@if ((int)ViewBag.Pages > 1)
{
    <div style="display:flex;gap:6px;margin-top:12px;justify-content:center">
        @for (int i = 1; i <= (int)ViewBag.Pages; i++)
        {
            <a asp-action="Index" asp-route-page="@i"
               style="padding:4px 10px;font-size:12px;border-radius:5px;border:1px solid @(i==(int)ViewBag.Page?"#185FA5":"#DDD");background:@(i==(int)ViewBag.Page?"#185FA5":"#fff");color:@(i==(int)ViewBag.Page?"#fff":"#555")">@i</a>
        }
    </div>
}
