@model HO.Domain.Entities.Store
@{
    ViewData["Title"] = Model.StoreName;
    var activeJob = ViewBag.ActiveFYJobId as string;
}

<!-- Two column layout -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
    <!-- Store Info -->
    <div class="card">
        <div class="card-header">Store Information</div>
        <div class="card-body">
            <table style="width:100%">
                <tr><td style="font-size:12px;color:#888;padding:5px 0;width:130px">Store Code</td>
                    <td style="font-family:monospace;font-weight:600;font-size:13px;padding:5px 0">@Model.StoreCode</td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">Region / Zone</td>
                    <td style="font-size:13px;padding:5px 0">@Model.Region / @Model.Zone</td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">Store Status</td>
                    <td style="padding:5px 0"><span style="background:#EAF3DE;color:#3B6D11;padding:2px 8px;border-radius:4px;font-size:12px">@Model.Status</span></td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">FY Close Status</td>
                    <td style="padding:5px 0">
                        @{
                            var sc = Model.FYCloseStatus.ToString() switch {
                                "Completed" => "status-completed",
                                "Failed" => "status-failed",
                                "Offline" => "status-offline",
                                _ => "status-pending"
                            };
                        }
                        <span class="badge @sc">@Model.FYCloseStatus</span>
                    </td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">Priority</td>
                    <td style="font-size:13px;padding:5px 0">P@Model.Priority</td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">Contact</td>
                    <td style="font-size:13px;padding:5px 0">@(Model.ContactEmail ?? "—")</td></tr>
                <tr><td style="font-size:12px;color:#888;padding:5px 0">Phone</td>
                    <td style="font-size:13px;padding:5px 0">@(Model.ContactPhone ?? "—")</td></tr>
            </table>
        </div>
    </div>

    <!-- Terminals -->
    <div class="card">
        <div class="card-header">Terminals (@Model.Terminals.Count)</div>
        <div class="p-0">
            <table>
                <thead>
                    <tr>
                        <th>Terminal</th><th>Status</th><th>Agent</th><th>Last Heartbeat</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var t in Model.Terminals)
                {
                    <tr>
                        <td>
                            <span style="font-family:monospace;font-size:12px;font-weight:600">@t.TerminalCode</span>
                            @if (t.IsPrimary) { <span style="font-size:10px;background:#E6F1FB;color:#185FA5;padding:1px 6px;border-radius:3px;margin-left:4px">PRIMARY</span> }
                        </td>
                        <td>
                            @{var ts = t.Status.ToString() switch { "Active"=>"status-completed",_=>"status-pending" };}
                            <span class="badge @ts" style="font-size:11px">@t.Status</span>
                        </td>
                        <td style="font-size:11px;color:#888">@(t.AgentVersion ?? "—")</td>
                        <td style="font-size:11px;color:#888">
                            @(t.LastHeartbeat.HasValue ? t.LastHeartbeat.Value.ToString("HH:mm dd-MMM") : "Never")
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.FYCloseStatus == HO.Domain.Enums.FYCloseStatus.Failed && !string.IsNullOrEmpty(activeJob))
{
    <div class="alert alert-warning" style="display:flex;align-items:center;gap:12px">
        <span style="flex:1">This store failed FY-Close execution. Choose an action:</span>
        <a href="/Store" class="btn btn-sm btn-outline">← Back to Stores</a>
    </div>
}
else
{
    <a href="/Store" class="btn btn-sm btn-outline" style="font-size:12px">← Back to Store Master</a>
}
