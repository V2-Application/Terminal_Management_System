<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] — RetailTMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="d-flex" style="min-height:100vh">

    <!-- Sidebar -->
    <nav style="width:210px;min-height:100vh;flex-shrink:0;background:#fff;border-right:0.5px solid #E0E0E0;display:flex;flex-direction:column">
        <div style="padding:14px 16px 10px;border-bottom:0.5px solid #E0E0E0">
            <div style="font-size:10px;color:#9E9E9E;font-weight:600;letter-spacing:.08em;text-transform:uppercase">Retail Network</div>
            <div style="font-size:15px;font-weight:600;color:#1F3864">FY-Close System</div>
            <div style="font-size:11px;color:#9E9E9E">Head Office Control</div>
        </div>
        <div style="flex:1;padding:6px 0">
            @{
                string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string NavLink(string c, string label, string icon) {
                    bool active = ctrl == c;
                    string border = active ? "border-left:2px solid #185FA5;" : "border-left:2px solid transparent;";
                    string bg     = active ? "background:#E6F1FB;" : "";
                    string color  = active ? "color:#185FA5;font-weight:500;" : "color:#6C757D;";
                    return $"<a href='/{c}' style='display:flex;align-items:center;gap:10px;padding:8px 14px;text-decoration:none;font-size:13px;{border}{bg}{color}'>{icon} {label}</a>";
                }
            }
            @Html.Raw(NavLink("Dashboard",  "Dashboard",       "▦"))
            @Html.Raw(NavLink("FYClose",    "FY-Close Control","⚙"))
            @Html.Raw(NavLink("Store",      "Store Master",    "≡"))
            @Html.Raw(NavLink("Terminal",   "Terminals",       "◈"))
            @Html.Raw(NavLink("Audit",      "Audit Logs",      "☰"))
        </div>
        <div style="padding:10px 14px;border-top:0.5px solid #E0E0E0">
            <div style="font-size:11px;color:#9E9E9E">@User.Identity?.Name</div>
            <a asp-controller="Account" asp-action="Logout" style="font-size:11px;color:#E74C3C;text-decoration:none">Sign out</a>
        </div>
    </nav>

    <!-- Main -->
    <div style="flex:1;display:flex;flex-direction:column;overflow:hidden">
        <!-- Topbar -->
        <div style="height:46px;background:#fff;border-bottom:0.5px solid #E0E0E0;padding:0 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
            <span style="font-size:14px;font-weight:500">@ViewData["Title"]</span>
            <span style="font-size:11px;color:#9E9E9E;font-family:monospace">FY2025 | RetailTMS v1.0</span>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible mx-4 mt-3 mb-0 py-2" style="font-size:13px">
                @TempData["Success"]
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible mx-4 mt-3 mb-0 py-2" style="font-size:13px">
                @TempData["Error"]
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>
            </div>
        }

        <main style="flex:1;overflow:auto;padding:20px">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
