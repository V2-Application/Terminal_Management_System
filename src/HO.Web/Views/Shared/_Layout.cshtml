<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>@ViewData["Title"] — RetailTMS</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:14px;background:#F5F7FA;color:#212529}
        a{text-decoration:none}
        /* Buttons */
        .btn{display:inline-block;padding:6px 14px;border-radius:6px;font-size:13px;cursor:pointer;border:1px solid transparent;font-weight:500}
        .btn-primary{background:#185FA5;color:#fff;border-color:#185FA5}
        .btn-primary:hover{background:#1a6bbf}
        .btn-secondary{background:#6C757D;color:#fff}
        .btn-danger{background:#dc3545;color:#fff}
        .btn-outline{background:#fff;color:#555;border-color:#DDD}
        .btn-outline:hover{background:#F0F4FF}
        .btn-sm{padding:3px 10px;font-size:12px}
        /* Cards */
        .card{background:#fff;border:1px solid #E8E8E8;border-radius:10px;overflow:hidden}
        .card-header{padding:12px 16px;background:#F8F9FA;border-bottom:1px solid #E8E8E8;font-size:13px;font-weight:600}
        .card-body{padding:16px}
        /* Tables */
        table{width:100%;border-collapse:collapse}
        th{font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.05em;padding:10px 14px;text-align:left;background:#F8F9FA;border-bottom:2px solid #E8E8E8;white-space:nowrap}
        td{padding:9px 14px;border-bottom:1px solid #F0F0F0;font-size:13px;vertical-align:middle}
        tr:hover td{background:#F5F8FF}
        /* Badges */
        .badge{padding:2px 9px;border-radius:4px;font-size:11px;font-weight:500}
        /* Forms */
        .form-control{width:100%;padding:8px 12px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;outline:none}
        .form-control:focus{border-color:#185FA5}
        .form-label{display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:5px}
        .form-select{width:100%;padding:8px 12px;border:1.5px solid #DDD;border-radius:6px;font-size:13px;outline:none;background:#fff}
        /* Alerts */
        .alert{padding:10px 14px;border-radius:6px;font-size:13px;border-left:3px solid}
        .alert-success{background:#EAF3DE;color:#3B6D11;border-color:#639922}
        .alert-danger{background:#FCEBEB;color:#A32D2D;border-color:#E74C3C}
        .alert-warning{background:#FAEEDA;color:#854F0B;border-color:#E67E22}
        /* Progress */
        .progress{height:8px;background:#E8E8E8;border-radius:4px;overflow:hidden}
        .progress-bar{height:100%;border-radius:4px;transition:width .5s}
        .bg-success{background:#639922}
        /* Utilities */
        .text-muted{color:#888!important}
        .fw-semibold{font-weight:600}
        .fw-bold{font-weight:700}
        .font-monospace{font-family:'Consolas','Courier New',monospace}
        .small{font-size:12px}
        .d-flex{display:flex}
        .gap-2{gap:8px}
        .align-items-center{align-items:center}
        .justify-content-between{justify-content:space-between}
        .flex-wrap{flex-wrap:wrap}
        .w-100{width:100%}
        .text-center{text-align:center}
        .mb-0{margin-bottom:0}
        .mb-1{margin-bottom:4px}
        .mb-2{margin-bottom:8px}
        .mb-3{margin-bottom:12px}
        .mb-4{margin-bottom:16px}
        .mt-2{margin-top:8px}
        .mt-3{margin-top:12px}
        .p-0{padding:0!important}
        .py-2{padding-top:8px;padding-bottom:8px}
        .px-3{padding-left:12px;padding-right:12px}
        .overflow-auto{overflow:auto}
        /* Status badges */
        .status-completed{background:#EAF3DE;color:#3B6D11}
        .status-failed{background:#FCEBEB;color:#A32D2D}
        .status-offline{background:#F1EFE8;color:#5F5E5A}
        .status-pending{background:#F0F0F0;color:#6C757D}
        .status-running{background:#FAEEDA;color:#854F0B}
        .status-skipped{background:#E8F4FD;color:#1A5276}
    </style>
</head>
<body>
<div style="display:flex;min-height:100vh">

    <!-- Sidebar -->
    <nav style="width:210px;min-width:210px;background:#fff;border-right:1px solid #E8E8E8;display:flex;flex-direction:column;flex-shrink:0">
        <div style="padding:14px 16px 10px;border-bottom:1px solid #E8E8E8">
            <div style="font-size:10px;color:#9E9E9E;font-weight:700;letter-spacing:.1em;text-transform:uppercase">Retail Network</div>
            <div style="font-size:16px;font-weight:700;color:#1F3864;margin-top:2px">RetailTMS</div>
            <div style="font-size:11px;color:#9E9E9E">Head Office Control Panel</div>
        </div>

        @{
            string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            string NavA(string c, string icon, string label) {
                bool on = ctrl.Equals(c, StringComparison.OrdinalIgnoreCase);
                return on
                    ? $"<a href='/{c}' style='display:flex;gap:10px;align-items:center;padding:9px 16px;font-size:13px;color:#185FA5;font-weight:600;background:#EBF3FB;border-left:3px solid #185FA5;'><span style='width:18px;text-align:center'>{icon}</span>{label}</a>"
                    : $"<a href='/{c}' style='display:flex;gap:10px;align-items:center;padding:9px 16px;font-size:13px;color:#6C757D;border-left:3px solid transparent;'><span style='width:18px;text-align:center'>{icon}</span>{label}</a>";
            }
        }
        <div style="flex:1;padding:6px 0">
            @Html.Raw(NavA("Dashboard","▦","Dashboard"))
            @Html.Raw(NavA("FYClose","⚙","FY-Close Control"))
            @Html.Raw(NavA("Store","☰","Store Master"))
            @Html.Raw(NavA("Terminal","◈","Terminals"))
            @Html.Raw(NavA("Audit","≡","Audit Logs"))
            <div style="height:1px;background:#F0F0F0;margin:6px 14px"></div>
            @Html.Raw(NavA("Admin","⚒","Admin / CRUD"))
        </div>

        <div style="padding:10px 14px;border-top:1px solid #E8E8E8">
            <div style="font-size:11px;color:#9E9E9E">@User.Identity?.Name</div>
            <a asp-controller="Account" asp-action="Logout"
               style="font-size:11px;color:#dc3545">Sign out</a>
        </div>
    </nav>

    <!-- Main -->
    <div style="flex:1;min-width:0;display:flex;flex-direction:column">
        <!-- Topbar -->
        <div style="height:48px;background:#fff;border-bottom:1px solid #E8E8E8;padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
            <span style="font-size:14px;font-weight:600;color:#1F3864">@ViewData["Title"]</span>
            <span style="font-size:11px;color:#9E9E9E;font-family:monospace">RetailTMS v1.0 | FY2025</span>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin:12px 20px 0">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger" style="margin:12px 20px 0">@TempData["Error"]</div>
        }

        <main style="flex:1;overflow:auto;padding:20px 24px">
            @RenderBody()
        </main>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
