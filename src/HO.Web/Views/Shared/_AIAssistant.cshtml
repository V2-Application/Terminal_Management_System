@* Claude AI Assistant Panel — include in Dashboard and FY-Close views via @await Html.PartialAsync("_AIAssistant") *@
<div class="card mt-3" id="ai-panel">
    <div class="card-header d-flex justify-content-between align-items-center"
         style="background:#1F3864;border-radius:10px 10px 0 0">
        <span class="text-white fw-semibold" style="font-size:13px">✦ Claude AI Assistant</span>
        <span class="badge" style="background:#2E75B6;font-size:10px">Anthropic</span>
    </div>
    <div class="card-body p-3">

        <!-- Auto-loaded AI batch summary -->
        <div id="ai-summary-box" class="mb-3 p-2 rounded"
             style="background:#F0F4FF;font-size:13px;min-height:38px;border-left:3px solid #185FA5">
            <span class="text-muted small">Loading AI summary...</span>
        </div>

        <!-- Chat history -->
        <div id="ai-chat-history" style="max-height:180px;overflow-y:auto;font-size:12px;
             border:0.5px solid #E0E0E0;border-radius:6px;padding:8px;background:#FAFAFA;margin-bottom:8px">
            <div class="text-muted small">Ask me about the current FY-Close batch...</div>
        </div>

        <!-- Input -->
        <div class="input-group input-group-sm">
            <input type="text" id="ai-chat-input" class="form-control"
                   placeholder="e.g. Why did ST042 fail? Is North region safe to retry?"
                   style="font-size:12px" />
            <button class="btn btn-sm" id="ai-chat-send"
                    style="background:#1F3864;color:white;font-size:12px">Ask ↗</button>
        </div>

        <!-- Quick question chips -->
        <div class="mt-2 d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" style="font-size:11px"
                    onclick="aiQuickAsk('How many stores are still pending?')">Pending?</button>
            <button class="btn btn-sm btn-outline-secondary" style="font-size:11px"
                    onclick="aiQuickAsk('What should I do about failed stores?')">Failed advice</button>
            <button class="btn btn-sm btn-outline-secondary" style="font-size:11px"
                    onclick="aiQuickAsk('Is it safe to continue to the next wave?')">Safe to continue?</button>
        </div>
    </div>
</div>

<script>
// AI panel initialises after DOM ready — safe in partial views
(function () {
    // Load summary on page load
    loadAISummary();

    document.getElementById('ai-chat-send')
        ?.addEventListener('click', sendAIChat);
    document.getElementById('ai-chat-input')
        ?.addEventListener('keydown', e => { if (e.key === 'Enter') sendAIChat(); });

    async function loadAISummary() {
        try {
            const r    = await fetch('/api/ai/batch-summary');
            const data = await r.json();
            const box  = document.getElementById('ai-summary-box');
            if (box) box.innerHTML =
                '<span style="color:#185FA5">✦</span> ' + data.summary;
        } catch {
            const box = document.getElementById('ai-summary-box');
            if (box) box.innerHTML = '<span class="text-muted small">AI summary unavailable</span>';
        }
    }

    async function sendAIChat() {
        const input = document.getElementById('ai-chat-input');
        if (!input) return;
        const msg = input.value.trim();
        if (!msg) return;

        appendChat('You', msg, '#E6F1FB', '#185FA5');
        input.value = '';

        try {
            const r    = await fetch('/api/ai/chat', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ message: msg })
            });
            const data = await r.json();
            appendChat('Claude', data.answer, '#F0F4FF', '#1F3864');
        } catch {
            appendChat('Claude', 'AI unavailable', '#FEF9E7', '#E67E22');
        }
    }

    window.aiQuickAsk = function (q) {
        const input = document.getElementById('ai-chat-input');
        if (input) { input.value = q; sendAIChat(); }
    };

    window.aiDiagnoseCommand = async function (commandId) {
        const btn = document.querySelector('[data-diagnose="' + commandId + '"]');
        if (btn) { btn.textContent = 'Analyzing...'; btn.disabled = true; }

        try {
            const r    = await fetch('/api/ai/diagnose/' + commandId, { method: 'POST' });
            const data = await r.json();
            appendChat('AI Diagnosis',
                'Root cause: ' + data.rootCause +
                ' | Action: ' + data.recommendedAction +
                ' | Safe to retry: ' + (data.isSafeToRetry ? 'Yes' : 'No'),
                '#FCEBEB', '#A32D2D');
        } catch {
            appendChat('AI', 'Diagnosis failed', '#FEF9E7', '#E67E22');
        }

        if (btn) { btn.textContent = 'AI Diagnose'; btn.disabled = false; }
    };

    function appendChat(sender, text, bg, color) {
        const h = document.getElementById('ai-chat-history');
        if (!h) return;
        const d = document.createElement('div');
        d.style.cssText = 'background:' + bg + ';color:' + color +
            ';padding:5px 8px;border-radius:4px;margin-bottom:4px;font-size:12px';
        d.innerHTML = '<strong>' + sender + ':</strong> ' +
            text.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        h.appendChild(d);
        h.scrollTop = h.scrollHeight;
    }
})();
</script>
