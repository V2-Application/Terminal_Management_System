@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>RetailTMS — Sign In</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:linear-gradient(135deg,#1F3864 0%,#2C5282 50%,#1A365D 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
        .card{background:#fff;border-radius:16px;padding:40px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,.3)}
        .logo{text-align:center;margin-bottom:28px}
        .logo h1{font-size:28px;font-weight:700;color:#1F3864;letter-spacing:-.5px}
        .logo p{font-size:13px;color:#888;margin-top:4px}
        .logo .badge{display:inline-block;background:#EBF3FB;color:#185FA5;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;margin-top:8px}
        .field{margin-bottom:18px}
        .field label{display:block;font-size:12px;font-weight:600;color:#444;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em}
        .field input{width:100%;padding:11px 14px;border:1.5px solid #E0E0E0;border-radius:8px;font-size:14px;outline:none;transition:border-color .2s,box-shadow .2s;background:#FAFAFA}
        .field input:focus{border-color:#185FA5;box-shadow:0 0 0 3px rgba(24,95,165,.1);background:#fff}
        .btn{width:100%;padding:12px;background:#1F3864;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s;letter-spacing:.3px;margin-top:4px}
        .btn:hover{background:#2C5282}
        .btn:active{background:#1A365D}
        .error{background:#FCEBEB;color:#A32D2D;border:1px solid #F5B8B8;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:18px;display:flex;align-items:center;gap:8px}
        .error::before{content:"⚠";font-size:15px}
        .divider{border:none;border-top:1px solid #F0F0F0;margin:20px 0}
        .roles{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px}
        .role-card{background:#F8F9FA;border-radius:8px;padding:10px 12px;border:1px solid #E8E8E8}
        .role-card .role-name{font-size:12px;font-weight:600;color:#1F3864}
        .role-card .role-cred{font-size:11px;color:#888;margin-top:2px;font-family:monospace}
    </style>
</head>
<body>
<div class="card">
    <div class="logo">
        <h1>RetailTMS</h1>
        <p>Head Office Control Panel</p>
        <span class="badge">500+ Store Network</span>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>

        <div class="field">
            <label>Username</label>
            <input name="username" type="text" autofocus autocomplete="username"
                   placeholder="Enter your username" required/>
        </div>

        <div class="field">
            <label>Password</label>
            <input name="password" type="password" autocomplete="current-password"
                   placeholder="Enter your password" required/>
        </div>

        <button class="btn" type="submit">Sign In →</button>
    </form>

    <hr class="divider"/>

    <div style="font-size:11px;color:#AAA;margin-bottom:10px;text-align:center;text-transform:uppercase;letter-spacing:.05em">
        Default accounts (change after first login)
    </div>
    <div class="roles">
        <div class="role-card">
            <div class="role-name">Super Admin</div>
            <div class="role-cred">admin / Admin@1234</div>
        </div>
        <div class="role-card">
            <div class="role-name">HO Admin</div>
            <div class="role-cred">hoadmin / HOAdmin@123</div>
        </div>
        <div class="role-card">
            <div class="role-name">Operator</div>
            <div class="role-cred">operator / Operator@123</div>
        </div>
        <div class="role-card">
            <div class="role-name">Viewer</div>
            <div class="role-cred">viewer / Viewer@123</div>
        </div>
    </div>
</div>
</body>
</html>
