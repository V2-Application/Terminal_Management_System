@{
    ViewData["Title"] = "Change Password";
}
<div style="max-width:420px;margin:40px auto">
    <div style="background:#fff;border:1px solid #E8E8E8;border-radius:12px;padding:28px">
        <h2 style="font-size:18px;font-weight:700;color:#1F3864;margin-bottom:6px">Change Password</h2>
        <p style="font-size:13px;color:#888;margin-bottom:20px">
            @(ViewBag.Forced == true ? "You must change your password before continuing." : "Update your account password.")
        </p>

        @if (ViewBag.Error != null)
        {
            <div style="background:#FCEBEB;color:#A32D2D;border-radius:6px;padding:10px 14px;font-size:13px;margin-bottom:16px">
                ⚠ @ViewBag.Error
            </div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:14px">
                <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:5px;text-transform:uppercase">Current Password</label>
                <input name="currentPassword" type="password" required
                       style="width:100%;padding:9px 12px;border:1.5px solid #DDD;border-radius:7px;font-size:14px;outline:none"/>
            </div>
            <div style="margin-bottom:14px">
                <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:5px;text-transform:uppercase">New Password</label>
                <input name="newPassword" type="password" required minlength="8"
                       style="width:100%;padding:9px 12px;border:1.5px solid #DDD;border-radius:7px;font-size:14px;outline:none"/>
                <div style="font-size:11px;color:#888;margin-top:4px">Minimum 8 characters</div>
            </div>
            <div style="margin-bottom:20px">
                <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:5px;text-transform:uppercase">Confirm New Password</label>
                <input name="confirmPassword" type="password" required
                       style="width:100%;padding:9px 12px;border:1.5px solid #DDD;border-radius:7px;font-size:14px;outline:none"/>
            </div>
            <button type="submit"
                    style="width:100%;padding:11px;background:#1F3864;color:#fff;border:none;border-radius:7px;font-size:14px;font-weight:600;cursor:pointer">
                Update Password
            </button>
        </form>
    </div>
</div>
